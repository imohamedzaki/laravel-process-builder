{
    "name": "mohamedzaki/laravel-process-builder",
    "description": "A visual process builder for designing Laravel routes, controllers, actions, validations, services, and application workflows.",
    "keywords": [
        "laravel",
        "process-builder",
        "workflow",
        "code-generation",
        "react-flow"
    ],
    "homepage": "https://github.com/imohamedzaki/laravel-process-builder",
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Mohamed Zaki",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^12.0 || ^13.0",
        "illuminate/support": "^12.0 || ^13.0",
        "illuminate/routing": "^12.0 || ^13.0",
        "illuminate/console": "^12.0 || ^13.0",
        "nikic/php-parser": "^5.0"
    },
    "require-dev": {
        "laravel/pint": "^1.18",
        "orchestra/testbench": "^9.0 || ^10.0",
        "phpstan/phpstan": "^1.12 || ^2.0",
        "larastan/larastan": "^2.9 || ^3.0",
        "phpunit/phpunit": "^11.0 || ^12.0"
    },
    "autoload": {
        "psr-4": {
            "MohamedZaki\\LaravelProcessBuilder\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MohamedZaki\\LaravelProcessBuilder\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/",
            "Workbench\\Database\\Factories\\": "workbench/database/factories/",
            "Workbench\\Database\\Seeders\\": "workbench/database/seeders/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "@clear",
            "@prepare"
        ],
        "clear": "@php vendor/bin/testbench package:purge-skeleton --ansi",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "build": "@php vendor/bin/testbench workbench:build --ansi",
        "serve": [
            "Composer\\Config::disableProcessTimeout",
            "@build",
            "@php vendor/bin/testbench serve --ansi"
        ],
        "test": "vendor/bin/phpunit",
        "analyse": "vendor/bin/phpstan analyse",
        "format": "vendor/bin/pint",
        "lint": [
            "@php vendor/bin/pint --ansi",
            "@php vendor/bin/phpstan analyse --verbose --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "MohamedZaki\\LaravelProcessBuilder\\LaravelProcessBuilderServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}